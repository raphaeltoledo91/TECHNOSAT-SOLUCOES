{
  "appId": "br.com.rafacarrastreadores.rafacar",
  "appName": "RAFACAR",
  "webDir": "www",
  "server": {
    "url": "https://rafacar-dev2-production.up.railway.app",
    "cleartext": false
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
